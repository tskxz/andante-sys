<Window x:Class="AndanteSys.Views.AdminWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndanteSys.Views"
        mc:Ignorable="d"
        Title="AndanteSys - Painel do Administrador" Height="550" Width="850"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Background="White" CornerRadius="5" Padding="15">
            <StackPanel>
                <TextBlock Text="Gestão de Títulos" FontSize="18" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,15"/>

                <Button x:Name="btnVoltar" Content="⬅️ Voltar ao Menu" Height="30" Background="#6C757D" Foreground="White" Click="BtnVoltar_Click" Margin="0,0,0,20"/>

                <TextBlock Text="Os controlos de criação vão ficar aqui..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" Margin="0,100,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Column="1" Margin="15,0,0,0">
            <Border Background="White" CornerRadius="5" Padding="15">
                <StackPanel>
                    <TextBlock Text="Cartões" FontSize="18" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,15"/>
                    <TextBlock Text="A tabela (DataGrid) vai ficar deste lado..." VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" Margin="0,150,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
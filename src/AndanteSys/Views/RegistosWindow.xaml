<Window x:Class="AndanteSys.Views.RegistosWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Histórico de Registos de Validação" Height="450" Width="700" WindowStartupLocation="CenterOwner">

    <Grid Margin="10">
        <TextBlock Text="Histórico de Validações" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
        <DataGrid x:Name="dgRegistos" Margin="0,40,0,0" AutoGenerateColumns="False" IsReadOnly="True" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Data / Hora" Binding="{Binding DataValidacao}" Width="160"/>
                <DataGridTextColumn Header="Resultado" Binding="{Binding Sucesso}" Width="80"/>
                <DataGridTextColumn Header="Zona" Binding="{Binding ZonaValidada}" Width="80"/>
                <DataGridTextColumn Header="Titular" Binding="{Binding Cartao.Titular.Nome}" Width="*"/>
                <DataGridTextColumn Header="Tipo Cartão" Binding="{Binding Cartao.TipoCartao}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>

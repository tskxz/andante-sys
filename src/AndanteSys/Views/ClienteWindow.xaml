<Window x:Class="AndanteSys.Views.ClienteWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AndanteSys.Views"
        mc:Ignorable="d"
        Title="AndanteSys - Área do Cliente" Height="500" Width="650"
        WindowStartupLocation="CenterScreen" Background="#F5F5F5">

    <Grid Margin="20">

        <Border x:Name="panelLogin" Background="White" CornerRadius="8" Padding="30" 
                VerticalAlignment="Center" HorizontalAlignment="Center" Width="450"
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="👤 ÁREA DO PASSAGEIRO" FontSize="20" FontWeight="Bold" Foreground="#28A745" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Por favor, aproxime o seu cartão virtual." FontSize="14" Foreground="#666" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Insira o NIF do Titular ou o ID do Cartão:" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,5"/>
                <TextBox x:Name="txtLoginInput" Height="35" FontSize="14" VerticalContentAlignment="Center" Margin="0,0,0,20"/>

                <Button x:Name="btnLogin" Content="Simular Encosto (Login)" Height="40" Background="#28A745" Foreground="White"  FontSize="14" FontWeight="Bold" Cursor="Hand"
                        Click="BtnLogin_Click" Margin="0,0,0,15"/>
                
                <Button x:Name="btnVoltarMenu1" Content="Voltar ao Menu Inicial" Height="30" Background="#6C757D" Foreground="White" Cursor="Hand"
                        Click="BtnVoltar_Click"/>
            </StackPanel>
        </Border>

        <Border x:Name="panelViagem" Background="White" CornerRadius="8" Padding="20" 
                Visibility="Collapsed" BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,15">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock x:Name="lblStatusSessao" Text="Sessão Ativa: [Nome do Cliente / Tipo]" FontSize="14" FontWeight="Bold" Foreground="#333"/>
                        <TextBlock x:Name="lblSaldoSessao" Text="Saldo/Estado: [Informação]" FontSize="12" Foreground="#666" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button x:Name="btnLogoff" Content="Retirar Cartão (Logoff)" DockPanel.Dock="Right" Height="30" Width="140" Background="#DC3545" Foreground="White" FontWeight="SemiBold" Cursor="Hand"
                            Click="BtnLogoff_Click"/>
                </DockPanel>

                <Separator Grid.Row="0" VerticalAlignment="Bottom"/>

                <Grid Grid.Row="1" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="260" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="1. Selecione a Estação de Embarque:" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,5"/>
                        <ComboBox x:Name="cbEstacoes" Height="35" FontSize="13" VerticalContentAlignment="Center" Margin="0,0,0,20" />

                        <Button x:Name="btnValidar" Content="VALIDAR VIAGEM" Height="45" Background="#007ACC" Foreground="White" FontSize="15" FontWeight="Bold" Cursor="Hand"
                                Click="BtnValidar_Click"
                                Margin="0,0,0,25"/>

                        <Border BorderBrush="#CCC" BorderThickness="1" Background="#F9F9F9" CornerRadius="5" Padding="15" Height="160" HorizontalAlignment="Stretch">
                            <Grid VerticalAlignment="Center">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Ellipse x:Name="ellipseLuz" Width="56" Height="56" Fill="LightGray" Stroke="#999" StrokeThickness="1" Margin="0,0,12,0" VerticalAlignment="Center" HorizontalAlignment="Center" />

                                <TextBlock x:Name="lblDisplayValidador" Grid.Column="1" Text="AGUARDANDO VALIDAÇÃO..." FontSize="16" FontWeight="Bold" Foreground="#555" TextWrapping="Wrap" VerticalAlignment="Center" TextAlignment="Center" />
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" Padding="10" Margin="15,0,0,0" Background="#FBFBFB">
                        <StackPanel>
                            <TextBlock Text="Zonas e Estações" FontSize="14" FontWeight="Bold" Foreground="#007ACC" Margin="0,0,0,8"/>
                            <TextBlock Text="Clique numa estação para seleccioná-la." FontSize="11" Foreground="#666" Margin="0,0,0,10"/>
                            <ScrollViewer Height="230" VerticalScrollBarVisibility="Auto">
                                <TreeView x:Name="tvZonas" />
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>